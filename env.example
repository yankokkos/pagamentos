# Configurações do Servidor
PORT=3000
NODE_ENV=production

# JWT Secret (altere em produção)
JWT_SECRET=medup-secret-key-change-in-production

# Asaas API
ASAAS_API_KEY=your_asaas_api_key_here
ASAAS_BASE_URL=https://www.asaas.com/api/v3

# Efí API (opcional)
EFI_CLIENT_ID=your_efi_client_id_here
EFI_CLIENT_SECRET=your_efi_client_secret_here
EFI_SANDBOX=true